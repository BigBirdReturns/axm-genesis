      "expected": "strasse"
    },
    {
      "input": "Tab\tand\nNewline",
      "expected": "tabandnewline",
      "comment": "tab (U+0009) and newline (U+000A) are category Cc: stripped, NOT treated as whitespace"
    },
    {
      "input": "bell\u0007char",
      "expected": "bellchar",
      "comment": "BEL (U+0007) is category Cc: stripped"
    },
    {
      "input": "a  b",
