      "input": "Istanbul",
      "expected": "istanbul",
      "comment": "ASCII I -> i"
    },
    {
      "input": "ıstanbul",
      "expected": "ıstanbul",
      "comment": "U+0131 LATIN SMALL LETTER DOTLESS I: survives unchanged"
    },
    {
      "input": "Café",
      "expected": "café",
      "comment": "e (U+0065) + COMBINING ACUTE (U+0301) composes to U+00E9 under NFC; same output as the precomposed input"
    },
    {
      "input": "Café",
      "expected": "café",
      "comment": "precomposed U+00E9: identical output to the combining-sequence input above"
    },
    {
      "input": "Маma",
      "expected": "Маma",
      "comment": "Cyrillic EM (U+041C) + Cyrillic a (U+0430) + Latin 'ma': the Cyrillic capital is NOT lowered"
    },
    {
      "input": "Mama",
      "expected": "mama",
      "comment": "all-Latin: distinct from the Cyrillic-confusable input above"
    },
    {
      "input": "АXM",
      "expected": "Аxm",
      "comment": "Cyrillic A (U+0410) + Latin 'XM': the Cyrillic capital survives"
    },
    {
      "input": "AXM",
      "expected": "axm",
      "comment": "all-Latin"
    },
    {
      "input": "a​b",
      "expected": "a​b",
      "comment": "U+200B ZERO WIDTH SPACE is category Cf: preserved, NOT whitespace"
    },
    {
      "input": "Null\u0000Byte",
      "expected_error": "ValueError",
      "comment": "NUL is the preimage field separator: canonicalize() MUST reject it"
    }
  ],
