      "comment": "NBSP (U+00A0) and EM SPACE (U+2003) are in the frozen whitespace set: collapsed to one ASCII space"
    },
    {
      "input": "Straße",
      "expected": "straße",
      "comment": "casefold expansion: U+00DF sharp s is NOT mapped to 'ss' (ASCII-only lowering)"
    },
    {
      "input": "ﬁle",
      "expected": "ﬁle",
      "comment": "U+FB01 LATIN SMALL LIGATURE FI: NFC preserves it (only NFKC decomposes)"
    },
    {
      "input": "ẞ",
      "expected": "ẞ",
      "comment": "U+1E9E LATIN CAPITAL LETTER SHARP S: not ASCII, survives unchanged"
    },
    {
