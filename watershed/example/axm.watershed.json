{
  "watershed": {
    "name": "axm",
    "version": "0.1.0",
    "basin": "axm-genesis",
    "maintainer": "BigBirdReturns"
  },
  "layers": [
    {
      "index": 0,
      "name": "protocol",
      "rule": "Defines vocabulary and verification. Depends on nothing above it. Extensions live here and only here."
    },
    {
      "index": 1,
      "name": "attention",
      "rule": "Orchestrates and observes through ledgers at runtime. Consumes protocol; no code dependency may point into this layer from anywhere.",
      "dependable": false
    },
    {
      "index": 2,
      "name": "instruments",
      "rule": "Produce ledgers from protocol vocabulary. Never depend on each other. Shared needs go down as extensions."
    },
    {
      "index": 3,
      "name": "publications",
      "rule": "Cite instrument outputs by hash and version. Depend on everything, depended on by nothing."
    }
  ],
  "extensions": [
    {
      "id": "temporal@1",
      "layer": 0,
      "defined_in": "axm-core",
      "spec": "spec/extensions/temporal-1.md"
    },
    {
      "id": "evidence-tiers@1",
      "layer": 0,
      "defined_in": "axm-core",
      "spec": "spec/extensions/evidence-tiers-1.md"
    },
    {
      "id": "embodied@1",
      "layer": 0,
      "defined_in": "axm-genesis",
      "spec": "spec/profiles/embodied@1.md"
    }
  ],
  "repos": [
    {
      "id": "axm-genesis",
      "url": "https://github.com/BigBirdReturns/axm-genesis",
      "layer": 0,
      "depends_on": [],
      "consumes_extensions": [],
      "status": "frozen",
      "release": "VERIFY: current tag",
      "produces": [
        "genesis kernel",
        "ML-DSA-44 signature roots"
      ]
    },
    {
      "id": "axm-core",
      "url": "https://github.com/BigBirdReturns/axm-core",
      "layer": 0,
      "depends_on": [
        "axm-genesis"
      ],
      "consumes_extensions": [],
      "status": "active",
      "release": "VERIFY",
      "produces": [
        "shard format",
        "extension specs",
        "BLAKE3 addressing"
      ]
    },
    {
      "id": "axm-verify",
      "url": "https://github.com/BigBirdReturns/axm-verify",
      "layer": 0,
      "depends_on": [
        "axm-genesis",
        "axm-core"
      ],
      "consumes_extensions": [],
      "status": "active",
      "release": "VERIFY",
      "produces": [
        "verification reports"
      ]
    },
    {
      "id": "ghostbox",
      "url": "VERIFY",
      "layer": 1,
      "depends_on": [
        "axm-core",
        "axm-verify"
      ],
      "consumes_extensions": [
        "temporal@1"
      ],
      "status": "active",
      "release": "VERIFY",
      "produces": [
        "level-2 attention records"
      ]
    },
    {
      "id": "screenghost",
      "url": "VERIFY",
      "layer": 1,
      "depends_on": [
        "axm-core"
      ],
      "consumes_extensions": [],
      "status": "active",
      "release": "VERIFY",
      "produces": [
        "commerce automation ledgers"
      ]
    },
    {
      "id": "clifford-number",
      "url": "https://github.com/BigBirdReturns/clifford-number",
      "layer": 2,
      "depends_on": [
        {
          "repo": "axm-core",
          "target": true
        }
      ],
      "consumes_extensions": [
        "temporal@1"
      ],
      "status": "active",
      "release": "VERIFY",
      "produces": [
        "hop-graph.json",
        "scores.json",
        "scout-report.md"
      ]
    },
    {
      "id": "offramp",
      "url": "https://github.com/BigBirdReturns/offramp",
      "layer": 2,
      "depends_on": [
        "axm-core"
      ],
      "consumes_extensions": [
        "evidence-tiers@1"
      ],
      "status": "incubating",
      "release": "unreleased",
      "produces": [
        "office cards",
        "monthly inventories",
        "questionnaire scores"
      ]
    },
    {
      "id": "pta-tracker",
      "url": "https://bigbirdreturns.github.io/axm-tools/pta-tracker",
      "layer": 2,
      "depends_on": [],
      "consumes_extensions": [],
      "status": "active",
      "release": "VERIFY",
      "produces": [
